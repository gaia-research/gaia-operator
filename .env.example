# Gaia Operator Environment Configuration
GAIA_OPERATOR_HOME=.gaia-operator
MARKETING_TASKS_PATH=../marketing-tasks
DEFAULT_DRIVER=hermes
DEFAULT_BROWSER=chromium
ENABLE_PUBLIC_WRITE=false
ENABLE_CUA=true
ENABLE_PLAYWRIGHT_MCP=false
REQUIRE_APPROVAL_FOR_L3=true
REQUIRE_APPROVAL_FOR_L4=true

# Fail-closed runtime controls
# Keep simulation disabled for real runs. Tests may set this explicitly.
GAIA_OPERATOR_ALLOW_SIMULATION=false
GAIA_OPERATOR_FAIL_ON_NETWORK_ERROR=false

# Use a transparent project user agent for public Reddit JSON reads.
# Replace contact=unset before running real platform tasks.
GAIA_OPERATOR_USER_AGENT="GaiaOperator/0.1.0 (+https://github.com/gaia-research/gaia-operator; public-community-research; contact=unset)"

# Optional browser user agent override. Prefer leaving empty unless a platform explicitly requires it.
# GAIA_OPERATOR_BROWSER_USER_AGENT=

# Optional API Credentials
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USERNAME=your_reddit_username
# REDDIT_PASSWORD=your_reddit_password
